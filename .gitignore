# This ignores all files generated by Unity.  
# It also ignores temporary files for stitching patches externally.
#  
# System files  
.DS_Store  
Thumbs.db  
# Visual Studio cache  
.vs/  
# Gradle files  
build/  
# Unity generated files  
[Ll]ibrary/  
[Tt]emp/  
[Oo]bj/  
[Bb]uild/  
[Bb]uilds/  
[Ll]ogs/  
# Backup files  
*.bak  
# Asset store tools  
[Aa]ssets/AssetStoreTools*  
# Autogenerated Jetbrains Rider plugin project files  
*.sln  
# Playable package logs  
*.pidb  
# TextMeshPro files  
Assets/TextMesh Pro/Resources/*.asset  
# IDEs  
.vscode/  
.idea/  
# Mac files  
*.swp  
*.swo  
# Windows files  
*.pdb  
# Asset cache files  
*.unityproj  
# Cache server files  
*.cache  
# Other  
*.apk  
*.unity  
*.asset  
*.prefab
